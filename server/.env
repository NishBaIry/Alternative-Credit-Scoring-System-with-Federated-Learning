# ============================================
# FL SERVER CONFIGURATION
# ============================================

# Server Network Settings
FL_SERVER_HOST=0.0.0.0
FL_SERVER_PORT=5000
FLASK_DEBUG=False

# Paths
UPLOAD_FOLDER=uploads
MODELS_FOLDER=models
BASE_MODEL_PATH=models/global_model.h5
GLOBAL_MODEL_PATH=models/global_model_latest.h5

# Validation Dataset Path (for accuracy comparison)
VALIDATION_DATASET_PATH=validation_data/validation_dataset.csv

# Aggregation Settings
# Minimum number of banks required before aggregation
AGGREGATION_THRESHOLD=2

# Model Validation
# Set to True to only update global model if accuracy improves
VALIDATE_BEFORE_REPLACE=True

# ============================================
# NOTES
# ============================================
# - AGGREGATION_THRESHOLD: Set to number of banks in FL system (e.g., 2 for Bank A and Bank B)
# - VALIDATE_BEFORE_REPLACE: If True, new model only replaces old if accuracy >= old accuracy
# - VALIDATION_DATASET_PATH: Dataset used to evaluate model accuracy before replacing
# - Adjust FL_SERVER_HOST to 0.0.0.0 to accept connections from other machines
