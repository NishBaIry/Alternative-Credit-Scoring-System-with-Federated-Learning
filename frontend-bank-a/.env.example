# Frontend Bank A Environment Variables (Example)
# Copy this to .env and update values as needed

# API Configuration
VITE_API_URL=http://localhost:8000

# Bank Configuration
VITE_BANK_ID=bank_a
VITE_BANK_NAME=Bank A
VITE_APP_TYPE=staff

# Score Configuration
VITE_SCORE_MIN=300
VITE_SCORE_MAX=900
VITE_SCORE_GOOD_THRESHOLD=700
VITE_SCORE_FAIR_THRESHOLD=600

# App Configuration
VITE_APP_TITLE=CashFlow - Bank A Staff Portal
