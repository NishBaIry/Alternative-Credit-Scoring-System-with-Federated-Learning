# Backend Environment Variables (Example)
# Copy this to .env and update values as needed

# Bank Configuration
BANK_ID=bank_a
BANK_NAME=Bank A

# Database Paths (SQLite)
BANK_A_DB=data/bank_a.db
BANK_B_DB=data/bank_b.db
NEW_APPLICATIONS_DB=data/new_applications.db
DATA_DIR=data

# Model Configuration
MODEL_DIR=models
GLOBAL_MODEL_PATH=models/global_model.h5
ACTIVE_MODEL_PATH=models/active_model.h5
SCALER_PATH=models/scaler.pkl
ENCODERS_PATH=models/encoders.pkl

# Scoring Configuration (Log-Odds formula)
SCORE_MIN=300
SCORE_MAX=900
SCORE_CENTER=600
LOG_ODDS_FACTOR=50

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Security
SECRET_KEY=your-secret-key-change-in-production-12345678
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Federated Learning Server
FL_SERVER_URL=http://localhost:5000
FL_EPOCHS=5
FL_BATCH_SIZE=256
FL_VALIDATION_SPLIT=0.2

# TensorFlow Configuration
TF_CPP_MIN_LOG_LEVEL=2
TF_ENABLE_ONEDNN_OPTS=0
